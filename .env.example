# =============================================
#  .env.example — 실제 사용 시 .env 로 복사하세요
#  절대 .env 파일을 Git에 커밋하지 마세요!
# =============================================

# Supabase 프로젝트 URL
# Supabase 대시보드 > Project Settings > API > Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase Anon (public) Key
# Supabase 대시보드 > Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Finnhub API ────────────────────────────────────────────────────────────
# 무료 가입: https://finnhub.io/register
# 대시보드 > API Key 에서 복사
# 무료 플랜: 60 req/분 REST, WebSocket 실시간 trade 포함
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here
